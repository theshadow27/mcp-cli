{
  "name": "mcp-cli",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "bun scripts/build.ts",
    "typecheck": "bun --bun tsc -b",
    "lint": "bunx biome check --write .",
    "lint:check": "bunx biome check .",
    "test": "bun test",
    "test:coverage": "bun scripts/check-coverage.ts",
    "dev:daemon": "bun packages/daemon/src/index.ts",
    "dev:mcx": "bun packages/command/src/index.ts",
    "dev:mcpctl": "bun packages/control/src/index.tsx",
    "prepare": "git config core.hooksPath .git-hooks"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  }
}
