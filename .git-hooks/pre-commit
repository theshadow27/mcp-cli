#!/usr/bin/env bash
# Pre-commit hook: typecheck, lint, and test must all pass.

set -euo pipefail

echo "Running pre-commit checks..."

echo "  typecheck..."
bun run typecheck

echo "  lint..."
bun run lint:check

echo "  test + coverage..."
if ! bun run test:coverage; then
  # check-coverage.ts already logs failures via test-failure-log.ts,
  # but if it crashed before logging, record a fallback entry
  echo "  (test failures logged to ~/.mcp-cli/test-failures.log)"
  exit 1
fi

echo "All checks passed."
