#!/usr/bin/env bash
# Pre-commit hook: typecheck, lint, and test — skips checks for non-code changes.
#
# Tiers:
#   docs-only  (.md, .claude/ docs)          → skip all checks
#   config-only (package.json, *.json config) → typecheck + lint only
#   source changes                            → full suite

set -euo pipefail

HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"

# Sprint-active guard (#1425, #1443) — reject commits to main's checkout
# while a sprint is active. Worktree commits and overrides are allowed.
# shellcheck source=sprint-active.sh
source "$HOOK_DIR/sprint-active.sh"
sprint_active_check || exit 1

# Get list of staged files (excludes deleted files)
staged_files=$(git diff --cached --name-only --diff-filter=d)

if [ -z "$staged_files" ]; then
  echo "No staged files, skipping checks."
  exit 0
fi

# Privacy: block staging of the local username in added/changed lines.
# Catches raw (/Users/<user>/ or /home/<user>/) and Claude-slug forms
# (-Users-<user>- where dots in usernames become dashes).
if [ -z "${SKIP_PRIVACY_CHECK:-}" ]; then
  user_raw="$USER"
  user_slug="${user_raw//./-}"
  privacy_pattern="(/Users/${user_raw}/|/home/${user_raw}/|-Users-${user_slug}-)"
  # Grep added lines only (not context, not removed). -U disables newline
  # normalization so we can reliably match within single diff lines.
  privacy_hits=$(git diff --cached -U0 --no-color -- $staged_files \
    | grep -E "^\+" | grep -E "$privacy_pattern" || true)
  if [ -n "$privacy_hits" ]; then
    echo "pre-commit: refusing to stage lines containing local home paths" >&2
    echo "pattern: $privacy_pattern" >&2
    echo "$privacy_hits" | head -20 >&2
    echo >&2
    echo "Redact the paths (use ~/ or <repo-root> or a generic placeholder)." >&2
    echo "If you are certain this is intentional, bypass with:" >&2
    echo "  SKIP_PRIVACY_CHECK=1 git commit ..." >&2
    exit 1
  fi
fi

# Classify staged files into tiers
# shellcheck source=classify.sh
source "$HOOK_DIR/classify.sh"
classify_files <<< "$staged_files"

# The static gate is a single command — `am-i-done --pre-commit` — which runs
# typecheck, lint:check, args-bounds, timeouts, teardown, phase-drift, and the
# FULL doing-it-wrong rule sweep (all rules, not just shell-injection). CI runs
# the identical command, so local and CI share one static definition of done
# (#2344). Source changes additionally run the test + coverage gate.
if $has_source; then
  echo "Running pre-commit checks (source changes detected)..."

  echo "  am-i-done (static gate: typecheck, lint, rules, phase-drift)..."
  bun run am-i-done --pre-commit

  echo "  test + coverage..."
  if ! bun run test:coverage; then
    echo "  (test failures logged to ~/.mcp-cli/test-failures.log)"
    exit 1
  fi

  echo "All checks passed."
elif $has_config; then
  echo "Running pre-commit checks (config-only changes, skipping tests)..."

  echo "  am-i-done (static gate: typecheck, lint, rules, phase-drift)..."
  bun run am-i-done --pre-commit

  echo "Config checks passed (tests skipped)."
else
  echo "Docs-only changes detected, skipping all checks."
fi
