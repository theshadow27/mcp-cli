{
  "compilerOptions": {
    "strict": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "types": ["bun"],
    "paths": {
      "@mcp-cli/core": ["./packages/core/src/index.ts"],
      "@mcp-cli/core/*": ["./packages/core/src/*"],
      "@mcp-cli/daemon": ["./packages/daemon/src/index.ts"],
      "@mcp-cli/daemon/*": ["./packages/daemon/src/*"],
      "@mcp-cli/permissions": ["./packages/permissions/src/index.ts"],
      "@mcp-cli/permissions/*": ["./packages/permissions/src/*"],
      "@mcp-cli/codex": ["./packages/codex/src/index.ts"],
      "@mcp-cli/codex/*": ["./packages/codex/src/*"],
      "@mcp-cli/acp": ["./packages/acp/src/index.ts"],
      "@mcp-cli/acp/*": ["./packages/acp/src/*"],
      "@mcp-cli/opencode": ["./packages/opencode/src/index.ts"],
      "@mcp-cli/opencode/*": ["./packages/opencode/src/*"],
      "@mcp-cli/command": ["./packages/command/src/main.ts"],
      "@mcp-cli/command/*": ["./packages/command/src/*"],
      "@mcp-cli/control": ["./packages/control/src/main.tsx"],
      "@mcp-cli/control/*": ["./packages/control/src/*"],
      "@mcp-cli/clone": ["./packages/clone/src/index.ts"],
      "@mcp-cli/clone/*": ["./packages/clone/src/*"]
    }
  },
  "include": ["packages/*/src/**/*.ts", "packages/*/src/**/*.tsx", "test/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
