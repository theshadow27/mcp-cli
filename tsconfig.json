{
  "compilerOptions": {
    "strict": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "types": ["bun"],
    "paths": {
      "@mcp-cli/core": ["./packages/core/src/index.ts"],
      "@mcp-cli/core/*": ["./packages/core/src/*"],
      "@mcp-cli/daemon": ["./packages/daemon/src/index.ts"],
      "@mcp-cli/daemon/*": ["./packages/daemon/src/*"],
      "@mcp-cli/command": ["./packages/command/src/index.ts"],
      "@mcp-cli/command/*": ["./packages/command/src/*"],
      "@mcp-cli/control": ["./packages/control/src/index.tsx"],
      "@mcp-cli/control/*": ["./packages/control/src/*"]
    }
  },
  "include": ["packages/*/src/**/*.ts", "packages/*/src/**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
